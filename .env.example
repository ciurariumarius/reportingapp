# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
AUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reportingapp?schema=public

# Admin login
ADMIN_USERNAME=admin
# Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=pbkdf2$100000$replace_salt$replace_hash

# Google Sheets / service account - used in a later integration phase
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# GA4
# Add this service account email as Viewer or higher on the GA4 property.
GA4_CLIENT_EMAIL=
# Keep private keys on one line with escaped newlines: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
GA4_PRIVATE_KEY=

# Meta Ads
# Create a Meta System User token with ads_read access to the configured ad accounts.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_API_VERSION=v23.0
